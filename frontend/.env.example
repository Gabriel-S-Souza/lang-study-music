# URL absoluta da API (produção real ou segundo túnel). Se definida, manda o fetch direto para cá.
# NEXT_PUBLIC_API_URL=https://sua-api.com

# Sem NEXT_PUBLIC_API_URL:
# - `next dev`: já usa /api/* via proxy interno.
# - `next build` + `next start`: coloque NEXT_PUBLIC_RELATIVE_API=1 AQUI antes do build para o mesmo proxy
#   (obrigatório no build — variável NEXT_PUBLIC_* entra no bundle).
# NEXT_PUBLIC_RELATIVE_API=1

# Alvo do proxy em dev / com RELATIVE_API (padrão http://127.0.0.1:8000)
# STUDY_API_PROXY_TARGET=http://127.0.0.1:8000
